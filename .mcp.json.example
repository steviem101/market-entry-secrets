{
  "mcpServers": {
    "gsc": {
      "command": "uvx",
      "args": ["mcp-search-console"],
      "env": {
        "GSC_OAUTH_CLIENT_SECRETS_FILE": "${HOME}/.config/gsc-mcp/client_secrets.json",
        "GSC_CONFIG_DIR": "${HOME}/.config/gsc-mcp",
        "GSC_ALLOW_DESTRUCTIVE": "false"
      }
    }
  }
}
