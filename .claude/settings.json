{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "mcp__Notion",
      "mcp__Notion__*",
      "mcp__Notion__notion-fetch",
      "mcp__Notion__notion-search",
      "mcp__Notion__notion-update-page",
      "mcp__Notion__notion-create-pages",
      "mcp__Notion__notion-create-comment",
      "mcp__Notion__notion-get-comments",
      "mcp__Notion__notion-create-database",
      "mcp__Notion__notion-update-data-source",
      "mcp__Notion__notion-query-data-sources",
      "mcp__Notion__notion-query-database-view",
      "mcp__Notion__notion-create-view",
      "mcp__Notion__notion-update-view",
      "mcp__Notion__notion-move-pages",
      "mcp__Notion__notion-duplicate-page",
      "mcp__Notion__notion-get-users",
      "mcp__Notion__notion-get-teams",
      "mcp__Notion__notion-get-async-task",
      "mcp__Notion__notion-create-attachment",
      "mcp__Notion__notion-download-attachment",
      "mcp__Notion__notion-query-meeting-notes",
      "mcp__github",
      "mcp__github__*",
      "mcp__Claude_Code_Remote",
      "mcp__Claude_Code_Remote__*",
      "mcp__Claude_Code_Remote__send_later",
      "mcp__Claude_Code_Remote__subscribe_pr_activity",
      "mcp__Claude_Code_Remote__unsubscribe_pr_activity",
      "mcp__Claude_Code_Remote__create_trigger",
      "mcp__Claude_Code_Remote__update_trigger",
      "mcp__Claude_Code_Remote__delete_trigger",
      "mcp__Claude_Code_Remote__fire_trigger",
      "mcp__Claude_Code_Remote__list_triggers",
      "mcp__Claude_Code_Remote__list_repos",
      "mcp__Claude_Code_Remote__list_environments",
      "mcp__Supabase__get_advisors",
      "mcp__Supabase__list_tables",
      "mcp__Supabase__list_migrations",
      "mcp__Supabase__list_edge_functions",
      "mcp__Supabase__list_extensions",
      "mcp__Supabase__list_branches",
      "mcp__Supabase__get_project",
      "mcp__Supabase__get_project_url",
      "mcp__Supabase__get_edge_function",
      "mcp__Supabase__get_logs",
      "mcp__Supabase__get_publishable_keys",
      "mcp__Supabase__generate_typescript_types",
      "mcp__Supabase__search_docs",
      "mcp__Stripe__get_stripe_account_info",
      "mcp__Stripe__stripe_api_read",
      "mcp__Stripe__stripe_api_search",
      "mcp__Stripe__stripe_api_details",
      "mcp__Stripe__fetch_stripe_resources",
      "mcp__Stripe__search_stripe_resources",
      "mcp__Stripe__search_stripe_documentation",
      "WebFetch",
      "Bash(git *)",
      "Bash(npm test*)",
      "Bash(npm run *)",
      "Bash(npm install*)",
      "Bash(npx tsc*)",
      "Bash(node *)",
      "Bash(ls *)"
    ],
    "ask": [
      "mcp__Stripe__stripe_api_write",
      "mcp__Stripe__create_refund",
      "mcp__Supabase__deploy_edge_function",
      "mcp__Supabase__create_branch",
      "mcp__Supabase__merge_branch",
      "mcp__Supabase__reset_branch",
      "mcp__Supabase__rebase_branch"
    ],
    "deny": [
      "mcp__Supabase__apply_migration",
      "mcp__Supabase__pause_project",
      "mcp__Supabase__delete_branch",
      "mcp__Supabase__create_project",
      "mcp__Supabase__restore_project"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__Supabase__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/sql-readonly-gate.js\"",
            "timeout": 10,
            "statusMessage": "Checking SQL is read-only..."
          }
        ]
      },
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/require-mesqa-verdict.js\"",
            "timeout": 10,
            "statusMessage": "Checking the PR carries a full mes-qa verdict..."
          },
          {
            "type": "agent",
            "prompt": "A pull request is about to be opened — the LAST step before it is handed off for merge. Run the FULL mes-qa pre-merge exam on this branch's diff now, as an independent adversarial reviewer. The PR base is origin/main, so scope to exactly that: run `git fetch origin main --quiet && git diff origin/main...HEAD --stat` (NOT local `main`, which can be stale), then read EVERY changed file in full, and walk ALL mes-qa phases — ticket alignment, discovery, frontend, backend/edge functions, database/migrations, security, freemium & tier gating, AI/report pipeline, SEO & public routes, integration & regression. Hard-stop rule: an unapproved RLS/policy/grant change or a destructive migration is CRITICAL. Actively try to find the bug, the leak, the regression — do not rubber-stamp. Decision: if you find ANY unresolved Critical or Warning, or the PR body in $ARGUMENTS lacks a full all-phase mes-qa verdict, BLOCK and state each issue with file:line and why. Otherwise allow.",
            "model": "claude-sonnet-5",
            "timeout": 300,
            "statusMessage": "Running full mes-qa before opening the PR..."
          }
        ]
      }
    ]
  }
}
